# 必填：DeepSeek API Key
# 从 https://platform.deepseek.com/ 获取（微信/支付宝充值，国内直连）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# 模型选择（默认 deepseek-chat 即 V3，功能最强）
# 可选：deepseek-reasoner（R1 推理模型）
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选：Tavily 搜索 API Key（用于网页搜索，不填则禁用）
TAVILY_API_KEY=
